  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '<b>TRAINING ZONE</b>



    <b>1. Activate Hand:</b> Press <b>[Y]</b>
    to control your Right Hand.

    <b>2. Grab Can:</b> Aim at the can on the table
    & hold <b>[G]</b>.

    <b>3. Walking Mode:</b> Press <b>[TAB]</b> to switch
    back to movement <b>[W, A, S, D]</b>.

    <b>4. Release:</b> Carry the can to
    the sink and press <b>[Y]</b> again to drop it.



    <b>Ready?</b> Go back
    to the main desk after <b>[TAB]</b> and click <b>START</b>.'
  m_isRightToLeft: 0
